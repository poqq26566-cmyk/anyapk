<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Auto-Update Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="更新"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/autoUpdateSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="应用自动更新检查"
            android:checked="true"
            android:paddingVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="应用启动时自动检查更新"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="16dp" />

        <!-- IP Configuration Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="网络配置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/networkStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="网络状态：检查中..."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/useDeviceIpSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="使用设备本地IP"
            android:checked="true"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/deviceIpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测到IP：加载中..."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <!-- Custom IP Input Section -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/customIpLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="自定义IP地址"
            android:enabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/customIpInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number|text"
                android:maxLines="1"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="输入用于ADB 配对的自定义IP地址（例如：192.168.1.100) "
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp" />

        <!-- IP Validation Error -->
        <TextView
            android:id="@+id/ipValidationError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?android:attr/colorError"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="16dp" />

        <!-- Info Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关于IP配置"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•设备本地IP：使用手机当前的WiFi IP地址(推荐) In· 自定义IP：当您的IP地址频繁变化或要连接特定设备时使用 "
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Check for Updates Button -->
        <Button
            android:id="@+id/checkUpdateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="检查更新"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存设置"
            android:minHeight="48dp" />

    </LinearLayout>

</ScrollView>
